{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [
    {
      "source": "/_shell",
      "destination": "/_shell.html"
    },
    {
      "source": "/((?!_shell|assets|favicon|android-chrome|apple-touch|site\\.webmanifest|robots).*)",
      "destination": "/_shell.html"
    }
  ]
}
